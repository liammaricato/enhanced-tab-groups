{
  "manifest_version": 3,
  "version": "1.0",
  "name": "Enhanced Tab Groups",
  "permissions": [
    "storage",
    "contextMenus",
    "tabs",
    "activeTab",
    "tabGroups"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_iconnn": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
